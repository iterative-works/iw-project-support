# PURPOSE: Load environment variables for Maven Central publishing.
# PURPOSE: Delegates secrets to .envrc.local which is gitignored.

# Maven Central publishing via Sonatype Central (secrets in .envrc.local)
# Required env vars:
#   MILL_SONATYPE_USERNAME  - from https://central.sonatype.com/usertoken
#   MILL_SONATYPE_PASSWORD  - from https://central.sonatype.com/usertoken
#
# Publish with (uses system GPG for signing):
#   mill mill.javalib.SonatypeCentralPublishModule/publishAll \
#     --publishArtifacts mill-iw-support.publishArtifacts --useGpgCli true

source_env_if_exists .envrc.local
